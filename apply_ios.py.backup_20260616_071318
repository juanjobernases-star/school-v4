#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
🍎 School v4 – Exploradores de Sexto
Instalador iOS Style – apply_ios.py
Genera: index.html, styles.css, app.js
260 preguntas LOMLOE + Motor Quiz/Examen/Chat IA dual + Diseño iOS
"""

import base64, os, sys, shutil
from datetime import datetime

BANNER = """
╔══════════════════════════════════════════════════════════════╗
║  🍎  School v4 – Instalador iOS Style                      ║
║  📚  Exploradores de Sexto · 260 preguntas LOMLOE           ║
║  🎓  6º de Primaria · Chat IA dual (Ollama + Groq)          ║
╚══════════════════════════════════════════════════════════════╝
"""

FILES = {
    "index.html": "",
    "styles.css": "",
    "app.js": "",
}

def main():
    print(BANNER)
    if len(sys.argv) > 1:
        target_dir = sys.argv[1]
    else:
        target_dir = os.path.dirname(os.path.abspath(__file__)) or "."
    os.makedirs(target_dir, exist_ok=True)
    print(f"📁 Directorio destino: {target_dir}")
    print()

    bk = 0
    for fname in FILES:
        fp = os.path.join(target_dir, fname)
        if os.path.exists(fp):
            bak = fp + ".bak." + datetime.now().strftime("%Y%m%d_%H%M%S")
            shutil.copy2(fp, bak)
            print(f"  💾 Backup: {fname} → {os.path.basename(bak)}")
            bk += 1
    if bk:
        print(f"  ({bk} backups creados)")
    else:
        print("  ℹ️  Instalación limpia (sin ficheros previos)")
    print()

    print("📝 Escribiendo ficheros...")
    for fname, data_b64 in FILES.items():
        fp = os.path.join(target_dir, fname)
        content = base64.b64decode(data_b64)
        with open(fp, "wb") as f:
            f.write(content)
        kb = len(content) / 1024
        print(f"  ✅ {fname} ({kb:.1f} KB)")

    print()
    print("═" * 60)
    print("🎉 ¡Instalación completada con éxito!")
    print("═" * 60)
    print()
    print("🚀 Para ejecutar en LOCAL:")
    print(f"   cd {target_dir}")
    print("   python3 -m http.server 8080")
    print("   → Abre: http://localhost:8080")
    print()
    print("🌐 Para GITHUB PAGES:")
    print("   git add index.html styles.css app.js")
    print('   git commit -m "School v4 – Exploradores de Sexto"')
    print("   git push origin main")
    print("   → URL: https://juanjobernases-star.github.io/school-v4/")
    print()
    print("📱 Características incluidas:")
    print("   • 260 preguntas LOMLOE (6 asignaturas)")
    print("   • Quiz (10 preguntas) + Examen semanal (20 preguntas, 15 min)")
    print("   • Chat IA dual: Ollama local (gemma2:2b) / Groq cloud")
    print("   • Progreso con barras de color por asignatura")
    print("   • Diseño Apple iOS con modo oscuro")
    print("   • Responsive: funciona en móvil y escritorio")
    print("   • Compatible: localhost:8080 + GitHub Pages")
    print()

if __name__ == "__main__":
    main()
